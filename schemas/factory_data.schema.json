{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factory-plan-optimizer.local/schemas/factory_data.schema.json",
  "title": "FactoryDataPackage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "items",
    "recipes",
    "final_demands",
    "external_supplies",
    "unmet_demand_penalty_rate"
  ],
  "properties": {
    "schema_version": {"const": "factory-data-v1"},
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/item"}
    },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/recipe"}
    },
    "final_demands": {"$ref": "#/$defs/nonnegativeNumberMap"},
    "external_supplies": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/id"},
      "additionalProperties": {"$ref": "#/$defs/externalSupply"}
    },
    "unmet_demand_penalty_rate": {"type": "number", "minimum": 0}
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\s]+$"
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["item", "fluid", "unknown"], "default": "unknown"},
        "category": {"$ref": "#/$defs/id", "default": "unknown"},
        "unlock_condition": {"$ref": "#/$defs/unlockCondition"}
      }
    },
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "coefficients", "production_cost"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "coefficients": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {"$ref": "#/$defs/id"},
          "additionalProperties": {
            "type": "number",
            "not": {"const": 0}
          }
        },
        "production_cost": {"type": "number", "minimum": 0},
        "category": {"$ref": "#/$defs/id", "default": "unknown"},
        "unlock_condition": {"$ref": "#/$defs/unlockCondition"}
      }
    },
    "unlockCondition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "id"],
          "properties": {
            "type": {"const": "technology"},
            "id": {"$ref": "#/$defs/id"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {"enum": ["start-unlocked", "unknown"]},
            "id": {"type": "null"}
          }
        }
      ]
    },
    "nonnegativeNumberMap": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/id"},
      "additionalProperties": {"type": "number", "minimum": 0}
    },
    "externalSupply": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cost"],
      "properties": {
        "cost": {"type": "number", "minimum": 0},
        "capacity": {
          "anyOf": [
            {"type": "number", "minimum": 0},
            {"type": "null"}
          ]
        }
      }
    }
  }
}
