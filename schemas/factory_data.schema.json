{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factory-plan-optimizer.local/schemas/factory_data.schema.json",
  "title": "FactoryDataPackage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "items",
    "recipes",
    "final_demands",
    "external_supplies",
    "unmet_demand_penalty_rate"
  ],
  "properties": {
    "schema_version": {"const": "factory-data-v2"},
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/item"}
    },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/recipe"}
    },
    "final_demands": {"$ref": "#/$defs/nonnegativeNumberMap"},
    "external_supplies": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/id"},
      "additionalProperties": {"$ref": "#/$defs/externalSupply"}
    },
    "milestones": {
      "type": "array",
      "items": {"$ref": "#/$defs/milestoneRecipeSet"},
      "default": []
    },
    "unmet_demand_penalty_rate": {"type": "number", "minimum": 0}
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\s]+$"
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["item", "fluid", "unknown"], "default": "unknown"},
        "category": {"$ref": "#/$defs/id", "default": "unknown"},
        "unlock_condition": {"$ref": "#/$defs/unlockCondition"}
      }
    },
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "coefficients",
        "energy_required",
        "ingredients",
        "results",
        "production_cost"
      ],
      "allOf": [
        {
          "if": {
            "properties": {"source_prototype_type": {"const": "boiler"}},
            "required": ["source_prototype_type"]
          },
          "then": {"required": ["source_prototype_name"]}
        }
      ],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "coefficients": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {"$ref": "#/$defs/id"},
          "additionalProperties": {
            "type": "number",
            "not": {"const": 0}
          }
        },
        "energy_required": {"type": "number", "exclusiveMinimum": 0},
        "ingredients": {
          "type": "array",
          "items": {"$ref": "#/$defs/recipeTerm"}
        },
        "results": {
          "type": "array",
          "items": {"$ref": "#/$defs/recipeTerm"}
        },
        "production_cost": {"type": "number", "minimum": 0},
        "category": {"$ref": "#/$defs/id", "default": "unknown"},
        "source_prototype_type": {"enum": ["recipe", "boiler"], "default": "recipe"},
        "source_prototype_name": {"$ref": "#/$defs/id"},
        "unlock_condition": {"$ref": "#/$defs/unlockCondition"}
      }
    },
    "recipeTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "anyOf": [
        {"required": ["amount"]},
        {"required": ["amount_min"]},
        {"required": ["amount_max"]}
      ],
      "properties": {
        "type": {"enum": ["item", "fluid", "unknown"]},
        "name": {"$ref": "#/$defs/id"},
        "amount": {"type": "number", "exclusiveMinimum": 0},
        "amount_min": {"type": "number", "exclusiveMinimum": 0},
        "amount_max": {"type": "number", "exclusiveMinimum": 0},
        "probability": {"type": "number", "minimum": 0, "maximum": 1},
        "catalyst_amount": {"type": "number", "minimum": 0},
        "temperature": {"type": "number", "minimum": 0},
        "minimum_temperature": {"type": "number", "minimum": 0},
        "maximum_temperature": {"type": "number", "minimum": 0},
        "fluidbox_index": {"type": "integer", "minimum": 0}
      }
    },
    "unlockCondition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "id"],
          "properties": {
            "type": {"const": "technology"},
            "id": {"$ref": "#/$defs/id"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {"enum": ["start-unlocked", "unknown"]},
            "id": {"type": "null"}
          }
        }
      ]
    },
    "nonnegativeNumberMap": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/id"},
      "additionalProperties": {"type": "number", "minimum": 0}
    },
    "externalSupply": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cost"],
      "properties": {
        "cost": {"type": "number", "minimum": 0},
        "capacity": {
          "anyOf": [
            {"type": "number", "minimum": 0},
            {"type": "null"}
          ]
        }
      }
    },
    "milestoneRecipeSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["milestone", "recipe_names", "diagnostics"],
      "properties": {
        "milestone": {"$ref": "#/$defs/id"},
        "recipe_names": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"}
        },
        "diagnostics": {
          "type": "array",
          "items": {"$ref": "#/$defs/diagnostic"}
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "message", "subject"],
      "properties": {
        "severity": {"enum": ["info", "warning", "error"]},
        "code": {"type": "string"},
        "message": {"type": "string"},
        "subject": {
          "anyOf": [
            {"type": "string"},
            {"type": "null"}
          ]
        }
      }
    }
  }
}
